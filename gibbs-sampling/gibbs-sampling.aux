\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {(a)}~Bimodal target with modes at $(\pm 3, \pm 3)$: Gibbs can mix (slowly) between modes. \textbf  {(b)}~Modes at $(\pm 5, \pm 5)$: Gibbs is completely stuck in one mode. \textbf  {(c)}~Trace plot showing the sampler trapped near $\theta _1 = 5$. \textbf  {(d)}~ESS (as \% of $N$) plummets with increasing $\rho $. }}{14}{figure.7}\protected@file@percent }
\newlabel{fig:failure}{{7}{14}{\textbf {(a)}~Bimodal target with modes at $(\pm 3, \pm 3)$: Gibbs can mix (slowly) between modes. \textbf {(b)}~Modes at $(\pm 5, \pm 5)$: Gibbs is completely stuck in one mode. \textbf {(c)}~Trace plot showing the sampler trapped near $\theta _1 = 5$. \textbf {(d)}~ESS (as \% of $N$) plummets with increasing $\rho $}{figure.7}{}}
